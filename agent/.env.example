GOOGLE_API_KEY=your-gemini-api-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Optional model override (default: gemini-2.5-flash)
# AGENT_MODEL=google_genai:gemini-2.5-flash

# Fallback model if primary hits quota (optional)
# GEMINI_MODEL_FALLBACK=gemini-2.5-flash-lite

# Skip deep agent — tools still run, verdict from rules (demo safety net)
# DEMO_MODE=false

# Optional comma-separated CORS origins (default: *)
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
